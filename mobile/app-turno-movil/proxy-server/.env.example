# Copiar a ".env" y ajustar. No contiene secretos: las credenciales del usuario
# viajan en cada request (login) y nunca se guardan aquí.

PORT=4000
MININGCONTROL_API_BASE=https://aura-aranzazu-dataapi.miningcontrol.cloud

# En local para pruebas puede quedar "*". En producción, poner la URL exacta
# donde quede publicada la PWA, ej: https://turno.auraminerals.com
ALLOWED_ORIGIN=*
